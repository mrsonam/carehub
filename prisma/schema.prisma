// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(PATIENT)

  /// Invited or staff accounts must change the initial password on first sign-in
  mustChangePassword Boolean @default(false)

  phone String?
  /// Professional / display title (e.g. MD, Clinical Lead)
  title String?
  bio   String?

  /// Set when a doctor (or other role) finishes the profile wizard
  profileCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id String @id @default(cuid())

  patientName String
  doctorName  String?

  // Store appointment date/time
  scheduledAt DateTime
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

